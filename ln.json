3publisher%3Dnewsstand%22%2C%22cdnAmpUrl%22%3A%22https%3A%2F%2Fwww-ndtv-com.cdn.ampproject.org%2Fc%2Fs%2Fwww.ndtv.com%2Findia-news%2Fshouldnt-have-left-her-in-that-house-twisha-sharmas-father-to-ndtv-11516106%2Famp%2F1%22%2C%22ampUrl%22%3A%22https%3A%2F%2Fwww.ndtv.com%2Findia-news%2Fshouldnt-have-left-her-in-that-house-twisha-sharmas-father-to-ndtv-11516106%2Famp%2F1%22%7D%2C%7B%22title%22%3A%22Figure%20AI%20had%20one%20of%20its%20robots%20race%20an%20intern%20to%20sort%20packages.%20See%20who%20lost.%22%2C%22content%22%3A%22%3Cfigure%3E%3Cimg%20width%3D%5C%221914%5C%22%20alt%3D%5C%22Figure%20AI%20intern%20vs.%20humanoid%5C%22%20src%3D%5C%22https%3A%2F%2Fi.insider.com%2F6a0bacac94eb4c909fb2db56%3Fformat%3Djpeg%5C%22%20height%3D%5C%221436%5C%22%3E%3Cfigcaption%3EA%20Figure%20AI%20intern%20competes%20against%20a%20humanoid.%3Cp%3EFigure%20AI%3C%2Fp%3E%3C%2Ffigcaption%3E%3C%2Ffigure%3E%3Cul%3E%3Cli%3EFigure%20AI%20pitted%20an%20intern%20against%20a%20humanoid%20in%20a%2010-hour-long%20package-sorting%20contest.%3C%2Fli%3E%3Cli%3EThe%20intern%20sorted%20192%20more%20packages%20than%20the%20robot%2C%20despite%20taking%20breaks.%3C%2Fli%3E%3Cli%3EFigure's%20robots%20have%20logged%20more%20than%20120%20hours%20of%20package%20sorting%20on%20a%20viral%20livestream.%3C%2Fli%3E%3C%2Ful%3E%3Cp%3EIn%20the%20first%20round%20of%20human%20vs.%20humanoid%2C%20the%20human%20emerged%20victorious%20%E2%80%94%20barely.%3C%2Fp%3E%3Cp%3EFor%20nearly%20a%20week%2C%20the%20%2439%20billion%20robotics%20startup%20%3Ca%20href%3D%5C%22https%3A%2F%2Fwww.businessinsider.com%2Ffigure-ai-turned-a-humanoid-sorting-packages-must-see-tv-2026-5%5C%22%20target%3D%5C%22%5C%22%3EFigure%20AI%3C%2Fa%3E%20has%20been%20livestreaming%20its%20robots%20placing%20packages%20barcode-side%20down%20on%20a%20conveyor%20belt%20at%20its%20San%20Jose%20headquarters.%20Millions%20have%20tuned%20in%20to%20watch%20the%20strangely%20compelling%20display%20of%20robotic%20drudgery.%3C%2Fp%3E%3Cp%3EThis%20weekend%2C%20Figure%20raised%20the%20stakes.%20The%20company%20brought%20in%20an%20intern%20to%20compete%20against%20one%20of%20its%20robots%20in%20a%2010-hour%20package-sorting%20contest.%20The%20intern%2C%20Aim%C3%A9%20G%C3%A9rard%2C%20works%20as%20a%20visualization%20specialist%2C%20according%20to%20LinkedIn.%3C%2Fp%3E%3Cp%3EG%C3%A9rard%20had%20the%20upper%20hand%20until%20biology%20took%20over.%20Around%20the%20five-hour%20mark%2C%20he%20stepped%20away%20for%20a%20bathroom%20break%2C%20and%20the%20humanoid%20pulled%20ahead.%20Under%20California%20labor%20law%2C%20G%C3%A9rard%20was%20entitled%20to%20meal%20and%20paid%20rest%20breaks.%3C%2Fp%3E%3Cp%3EG%C3%A9rard%20bounced%20back%2C%20despite%20the%20disadvantage%20of%20being%20human.%20After%2010%20hours%20of%20grueling%20work%20that%20apparently%20%3Ca%20href%3D%5C%22https%3A%2F%2Fx.com%2Fadcock_brett%2Fstatus%2F2056212645142020324%5C%22%20target%3D%5C%22_blank%5C%22%3Eleft%20the%20intern%20with%20blisters%3C%2Fa%3E%2C%20he%20sorted%2012%2C924%20packages%20%E2%80%94%20192%20more%20than%20his%20robot%20rival.%20G%C3%A9rard%20averaged%202.79%20seconds%20per%20package%3B%20the%20humanoid%20averaged%202.83.%3C%2Fp%3E%3Cp%3E%26quot%3BThis%20is%20the%20last%20time%20a%20human%20will%20ever%20win%2C%26quot%3B%20Figure%20AI%20founder%20and%20CEO%20Brett%20Adcock%20wrote%20on%20X.%3C%2Fp%3E%3Cp%3EA%20coterie%20of%20humanoid%20robots%20has%20been%20sorting%20packages%20on%20a%20looped%20conveyor%20belt%20at%20Figure's%20headquarters%20since%20last%20Wednesday.%20The%20exercise%20aims%20to%20show%20potential%20customers%20that%20Figure%20AI's%20humanoids%20can%20work%20reliably%20for%20long%20stretches%2C%20including%2024-hour%20shifts%2C%20Figure%20AI%20investor%20and%20board%20member%20Jesse%20Coors-Blankenship%20told%20Business%20Insider%20last%20week.%3C%2Fp%3E%3Cp%3EFigure%20AI%20first%20set%20out%20last%20Wednesday%20to%20have%20its%20humanoids%20complete%20an%20eight-hour%20stretch%20of%20autonomous%20labor.%20One%20robot%20sorted%20packages%20while%20two%20others%20stood%20on%20chargers%20in%20the%20background%2C%20ready%20to%20sub%20in%20when%20their%20colleague%20needed%20to%20power%20up.%20By%20the%20end%20of%20the%20first%20eight%20hours%2C%20the%20livestream%20had%20drawn%20more%20than%201.5%20million%20views%20on%20X%2C%20and%20viewers%20had%20named%20the%20robots%20Bob%2C%20Frank%2C%20and%20Gary.%3C%2Fp%3E%3Cp%3ETwenty-four%20hours%20later%2C%20the%20humanoids%20had%20sorted%20more%20than%2030%2C000%20packages%20and%20attracted%20more%20than%203%20million%20cumulative%20views%20on%20X.%20The%20livestream%20is%20still%20going%20six%20days%20later.%3C%2Fp%3E%3Cp%3EAdcock%20has%20said%20the%20livestream%20will%20continue%20until%20the%20robots%20fail.%20Viewers%20have%20%3Ca%20href%3D%5C%22https%3A%2F%2Fx.com%2FJason%2Fstatus%2F2054635291860668517%5C%22%20target%3D%5C%22_blank%5C%22%3Ecalled%20the%20feed%20%26quot%3Bsurprisingly%20addicting%26quot%3B%3C%2Fa%3E%20and%20%26quot%3B%3Ca%20href%3D%5C%22https%3A%2F%2Fx.com%2FJason%2Fstatus%2F2054635291860668517%5C%22%20target%3D%5C%22_blank%5C%22%3Erobotic%20ASMR%3C%2Fa%3E%2C%26quot%3B%20and%20Figure%20has%20even%20started%20selling%20merch%20of%20its%20package-sorting%20humanoids.%3C%2Fp%3E%3Cp%3EFigure%20has%20previously%20shared%20a%20video%20of%20its%20humanoids%20doing%20chores%2C%20such%20as%20%3Ca%20href%3D%5C%22https%3A%2F%2Fwww.businessinsider.com%2Ffigure-ai-robots-humanoids-make-a-bed-video-2026-5%5C%22%20target%3D%5C%22%5C%22%3Emaking%20a%20bed%3C%2Fa%3E.%3C%2Fp%3E%3Cp%3EThe%20robots'%20ability%20to%20operate%20for%20so%20long%20without%20failure%20was%20impressive%2C%20though%20the%20technology%20is%20not%20ready%20for%20deployment%20because%20of%20accuracy%20issues%2C%20said%20roboticist%20Ayanna%20Howard%2C%20dean%20of%20Ohio%20State%20University's%20College%20of%20Engineering.%20These%20issues%20include%20packages%20placed%20barcode-side%20up%20and%20packages%20occasionally%20being%20knocked%20off%20the%20belt.%3C%2Fp%3E%3Cp%3E%26quot%3BWe're%20a%20long%20way%20away%20from%20a%20fully%20autonomous%20humanoid%20in%20a%20logistics%20center%2C%26quot%3B%20said%20Howard.%3C%2Fp%3E%3Cdiv%3ERead%20the%20original%20article%20on%20%3Ca%20href%3D%5C%22https%3A%2F%2Fwww.businessinsider.com%2Ffigure-ai-intern-beats-robot-in-package-sorting-challenge-2026-5%5C%22%3EBusiness%20Insider%3C%2Fa%3E%3C%2Fdiv%3E%22%2C%22published%22%3A1779181201000%2C%22visual%22%3A%22https%3A%2F%2Fi.insider.com%2F6a0bac7aecd7cc1332bb0ecb%3Fformat%3Djpeg%22%2C%22originID%22%3A%22https%3A%2F%2Fwww.businessinsider.com%2Ffigure-ai-intern-beats-robot-in-package-sorting-challenge-2026-5%22%2C%22summary%22%3A%22Figure%20AI's%20intern%20outperformed%20a%20humanoid%20robot%20in%20a%20package%20sorting%20contest%2C%20highlighting%20the%20challenges%20in%20robotics%20automation.%22%2C%22author%22%3A%22rjetha%40insider.com%20(Rya%20Jetha)%22%2C%22engagement%22%3A99%2C%22canonicalUrl%22%3A%22%22%2C%22cdnAmpUrl%22%3A%22%22%2C%22ampUrl%22%3A%22%22%7D%2C%7B%22title%22%3A%22%E2%80%98Baywatch%E2%80%99%20Set%20to%20Make%20a%20Splash%20Across%20the%20Pond%20as%20Sky%20Snaps%20Up%20U.K.%20and%20Ireland%20Rights%22%2C%22content%22%3A%22%22%2C%22published%22%3A1779181200000%2C%22visual%22%3A%22%22%2C%22originID%22%3A%22https%3A%2F%2Fvariety.com%2F%3Fp%3D1236753343%22%2C%22summary%22%3A%22%E2%80%9CBaywatch%E2%80%9D%20is%20set%20to%20make%20a%20splash%20in%20the%20U.K.%20and%20Ireland%20after%20Comcast-owned%20broadcaster%20Sky%20snapped%20up%20the%20rights%20to%20the%20show.%20The%20beach-set%20drama%2C%20which%20is%20due%20to%20launch%20in%202027%2C%20will%20be%20available%20on%20Sky%20and%20its%20companion%20streaming%20platform%20Now%20after%20the%20broadcaster%20struck%20a%20deal%20with%20distributor%20Fremantle.%20The%20show%2C%20%5B%E2%80%A6%5D%22%2C%22author%22%3A%22K.J.%20Yossman%22%2C%22engagement%22%3A0%2C%22canonicalUrl%22%3A%22%22%2C%22cdnAmpUrl%22%3A%22%22%2C%22ampUrl%22%3A%22%22%7D%2C%7B%22title%22%3A%22Israeli%20forces%20board%20Gaza-bou